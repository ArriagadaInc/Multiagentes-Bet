# ============================================================================
# Configuración de Variables de Entorno para Agente #2 (Odds Fetcher)
# ============================================================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como .env en el mismo directorio
# 2. Reemplazar los valores con tus valores reales
# 3. No compartir .env en git (agregar a .gitignore)
# 4. Recargue Python/terminal después de cambiar .env
#
# ============================================================================

# ===== REQUERIDO =====
# API Key de The Odds API (https://the-odds-api.com)
# Obtén la tuya en: https://the-odds-api.com/account
# Plan free incluye 500 llamadas/mes
ODDS_API_KEY=sk_live_YOUR_API_KEY_HERE

# ===== CONFIGURACIÓN DE API =====
# Regiones de bookmakers a consultar
# Valores comunes: "eu" (Europa, default), "us" (USA), "br" (Brasil), "au" (Australia)
# Región determina qué bookmakers se retornan (mercados locales)
ODDS_REGIONS=eu

# Mercados de apuestas a consultar
# "h2h" = Head to Head (1X2, equivalente a tres caminos)
# Otros soportados en v4: spreads, totals, etc. (menor soporte actualmente)
# Default y recomendado por MVP: h2h
ODDS_MARKETS=h2h

# Formato de odds en la respuesta
# "decimal" = 2.50 (recomendado, fácil compilación)
# "american" = +150 o -200
# "fractional" = 3/2
# Default y recomendado: decimal
ODDS_FORMAT=decimal

# Bookmakers específicos a incluir (opcional)
# Si está vacío, incluye TODOS los bookmakers disponibles
# Si quieres filtrar, lista las claves coma-separadas
# Ejemplos:
#   ODDS_BOOKMAKERS=draftkings,betmgm,fanduel
#   ODDS_BOOKMAKERS=skybet,betfair
# Dejar vacío O comentado para incluir todos
# ODDS_BOOKMAKERS=

# ===== CACHING =====
# Tiempo de vida del cache en segundos
# El cache reduce costos de API significativamente
# - TTL bajo (5-60s): Información más fresca, más API calls
# - TTL alto (600-3600s): Costo bajo, datos potencialmente stale
# Recomendaciones:
#   Desarrollo/testing: 5 segundos
#   Producción 1-2x/día: 600-900 segundos (10-15 minutos)
#   Producción 24/7: 1800+ segundos (30+ minutos)
ODDS_CACHE_TTL_SECONDS=600

# ===== TIMEOUTS Y REINTENTOS =====
# Timeout para requests HTTP en segundos
# Si la API tarda más, se cancela la llamada y se reintenta
# Default: 20 segundos (razonable para API remota)
# Aumentar si tienes conexión lenta
ODDS_TIMEOUT_SECONDS=20

# Número máximo de reintentos automáticos
# En caso de fallo temporal (timeout, 5xx, etc), reintentar
# Backoff exponencial: 1s, 2s, 4s, 8s...
# Default: 2 (3 intentos totales: inicial + 2 reintentos)
ODDS_RETRIES=2

# ===== LOGGING =====
# Nivel de logging (opcional, afecta verbosidad)
# DEBUG = Muy detallado (development)
# INFO = Normal (production)
# WARNING = Solo errores importantes
# Nota: Si no está set, usa defaults en código Python
# LOG_LEVEL=INFO

# ===== NOTAS ADICIONALES =====
#
# - The Odds API v4: https://the-odds-api.com/apidocs
# - Rate limits (free): 500 requests/month típicamente
# - Pricing: $0.002 per request (después del free tier)
# - Sport keys válidos (este MVP):
#   * soccer_uefa_champs_league (Champions League)
#   * soccer_chile_campeonato (Primera División Chilena)
#
# ============================================================================
